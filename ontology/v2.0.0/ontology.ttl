@base <http://pokemon.ontology.com> .

<http://pokemon.ontology.com#> rdf:type owl:Ontology ;
			 dc:title "Ontologia de Pokemon"@es ;
    		dc:creator "Manuel Bravo, " ;
    		dc:description "Ontologia para relacionar pokemons con sus evoluciones, atributos, habilidades, stats..."@es ;
    		dc:date "2026-05-10"^^xsd:date ;
			owl:versionInfo "2.0.0" ;
			owl:versionIRI <http://pokemon.ontology.com/ontology/2.0.0> ;
			mod:createdWith <https://chowlk.linkeddata.es/> .



#################################
# SKOS Concept Scheme
#################################

poke:TiposPokemon rdf:type skos:ConceptScheme ;
    skos:prefLabel "Tipos Pokemon"@es .


poke:Fire rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Fuego"@es ;
    skos:prefLabel "Fire"@en ;
    skos:inScheme poke:TiposPokemon .

poke:Water rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Agua"@es ;
    skos:prefLabel "Water"@en ;
    skos:inScheme poke:TiposPokemon .

poke:Flying rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Volador"@es ;
    skos:prefLabel "Flying"@en ;
    skos:inScheme poke:TiposPokemon .

poke:Electric rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Electrico"@es ;
    skos:prefLabel "Electric"@en ;
    skos:inScheme poke:TiposPokemon .

poke:Grass rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Planta"@es ;
    skos:prefLabel "Grass"@en ;
    skos:inScheme poke:TiposPokemon .

poke:Poison rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Veneno"@es ;
    skos:prefLabel "Poison"@en ;
    skos:inScheme poke:TiposPokemon .

poke:Bug rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Bicho"@es ;
    skos:prefLabel "Bug"@en ;
    skos:inScheme poke:TiposPokemon .


poke:Normal rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Normal"@es ;
    skos:prefLabel "Normal"@en ;
    skos:inScheme poke:TiposPokemon .

poke:Ground rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Tierra"@es ;
    skos:prefLabel "Ground"@en ;
    skos:inScheme poke:TiposPokemon .

poke:Fairy rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Hada"@es ;
    skos:prefLabel "Fairy"@en ;
    skos:inScheme poke:TiposPokemon .

poke:Fighting rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Lucha"@es ;
    skos:prefLabel "Fighting"@en ;
    skos:inScheme poke:TiposPokemon .

poke:Psychic rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Psiquico"@es ;
    skos:prefLabel "Psychic"@en ;
    skos:inScheme poke:TiposPokemon .

poke:Rock rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Roca"@es ;
    skos:prefLabel "Rock"@en ;
    skos:inScheme poke:TiposPokemon .

poke:Steel rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Acero"@es ;
    skos:prefLabel "Steel"@en ;
    skos:inScheme poke:TiposPokemon .

poke:Ice rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Hielo"@es ;
    skos:prefLabel "Ice"@en ;
    skos:inScheme poke:TiposPokemon .

poke:Ghost rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Fantasma"@es ;
    skos:prefLabel "Ghost"@en ;
    skos:inScheme poke:TiposPokemon .

poke:Dragon rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Dragon"@es ;
    skos:prefLabel "Dragon"@en ;
    skos:inScheme poke:TiposPokemon .

poke:Dark rdf:type poke:Tipo , skos:Concept ;
    skos:prefLabel "Siniestro"@es ;
    skos:prefLabel "Dark"@en ;
    skos:inScheme poke:TiposPokemon .




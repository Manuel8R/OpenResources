###############
#Restricciones
###############

#restricciones del nevo tieneTipo min 1 max 2
poke:Pokemon rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty poke:tieneTipo ;
    owl:minCardinality "1"^^xsd:nonNegativeInteger
] .

poke:Pokemon rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty poke:tieneTipo ;
    owl:maxCardinality "2"^^xsd:nonNegativeInteger
] .


#inverso evolucionaA
poke:evolucionaA owl:inverseOf poke:evolucionaDe .


#disjoins

poke:Pokemon owl:disjointWith poke:Movimiento .
poke:Pokemon owl:disjointWith poke:Tipo .
poke:Movimiento owl:disjointWith poke:Tipo .




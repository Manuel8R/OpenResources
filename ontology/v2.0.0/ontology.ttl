###############
#SubClases
###############



#Todos los tipos de pokemon, obliganto a tiene tipo a ser el mismo, puede ser el mismo poke de 2 subclases

poke:PokemonFuego rdf:type owl:Class ;
    rdfs:subClassOf poke:Pokemon ;
    owl:equivalentClass [
        rdf:type owl:Restriction ;
        owl:onProperty poke:tieneTipo ;
        owl:hasValue poke:Fire
    ] ;
    rdfs:label "Pokemon Fuego" .

poke:PokemonPlanta rdf:type owl:Class ;
    rdfs:subClassOf poke:Pokemon ;
    owl:equivalentClass [
        rdf:type owl:Restriction ;
        owl:onProperty poke:tieneTipo ;
        owl:hasValue poke:Grass
    ] ;
    rdfs:label "Pokemon Planta" .


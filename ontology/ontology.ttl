@prefix : <http://pokemon.ontology.com#> .
@prefix mod: <https://w3id.org/mod#> .
@prefix ns: <http://www.owl-ontologies.com/ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

: a owl:Ontology ;
    mod:createdWith <https://chowlk.linkeddata.es/> .

ns:AprendeMovimiento a owl:ObjectProperty ;
    rdfs:label "aprende movimiento" ;
    rdfs:domain ns:Pokemon ;
    rdfs:range ns:Movimiento .

ns:E_SP_attack a owl:DatatypeProperty ;
    rdfs:label "e_ s p_attack" .

ns:E_SP_defense a owl:DatatypeProperty ;
    rdfs:label "e_ s p_defense" .

ns:E_attack a owl:DatatypeProperty ;
    rdfs:label "e_attack" .

ns:E_defense a owl:DatatypeProperty ;
    rdfs:label "e_defense" .

ns:E_speed a owl:DatatypeProperty ;
    rdfs:label "e_speed" .

ns:EsDeTipo a owl:ObjectProperty ;
    rdfs:label "es de tipo" ;
    rdfs:domain ns:Movimiento ;
    rdfs:range ns:Tipo .

ns:EvolucionaA a owl:ObjectProperty ;
    rdfs:label "evoluciona a" ;
    rdfs:domain ns:Pokemon ;
    rdfs:range ns:Pokemon .

ns:HP a owl:DatatypeProperty ;
    rdfs:label "h p" .

ns:Habilidad a owl:Class ;
    rdfs:label "Habilidad" .

ns:PokemonLegendario a owl:Class ;
    rdfs:label "Pokemon Legendario" ;
    rdfs:subClassOf ns:Pokemon .

ns:SP_attack a owl:DatatypeProperty ;
    rdfs:label "s p_attack" .

ns:SP_defense a owl:DatatypeProperty ;
    rdfs:label "s p_defense" .

ns:TieneHabilidad a owl:ObjectProperty ;
    rdfs:label "tiene habilidad" .

ns:TieneMegaEvolucion a owl:ObjectProperty ;
    rdfs:label "tiene mega evolucion" ;
    rdfs:domain ns:Pokemon ;
    rdfs:range ns:Pokemon .

ns:TieneRangoExp a owl:ObjectProperty ;
    rdfs:label "tiene rango exp" ;
    rdfs:domain ns:Pokemon ;
    rdfs:range ns:Tipoexperiencia .

ns:TieneTipo a owl:ObjectProperty ;
    rdfs:label "tiene tipo" ;
    rdfs:range ns:Tipo .

ns:Total a owl:DatatypeProperty ;
    rdfs:label "total" .

ns:attack a owl:DatatypeProperty ;
    rdfs:label "attack" .

ns:defense a owl:DatatypeProperty ;
    rdfs:label "defense" .

ns:esDebilContra a owl:ObjectProperty ;
    rdfs:label "es debil contra" ;
    rdfs:domain ns:Tipo ;
    rdfs:range ns:Tipo .

ns:esEvolucionFinal a owl:DatatypeProperty ;
    rdfs:label "es evolucion final" .

ns:esFuertecontra a owl:ObjectProperty ;
    rdfs:label "es fuertecontra" ;
    rdfs:domain ns:Tipo ;
    rdfs:range ns:Tipo .

ns:perteneceAGrupoHuevo a owl:ObjectProperty ;
    rdfs:label "pertenece a grupo huevo" ;
    rdfs:domain ns:Pokemon ;
    rdfs:range ns:Grupohuevo .

ns:speed a owl:DatatypeProperty ;
    rdfs:label "speed" .

ns:Grupohuevo a owl:Class ;
    rdfs:label "Grupohuevo" .

ns:Tipoexperiencia a owl:Class ;
    rdfs:label "Tipoexperiencia" .

ns:Movimiento a owl:Class ;
    rdfs:label "Movimiento" .

ns:Tipo a owl:Class ;
    rdfs:label "Tipo" .

ns:Pokemon a owl:Class ;
    rdfs:label "Pokemon" .


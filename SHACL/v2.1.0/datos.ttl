@prefix poke: <https://w3id.org/doisr/PokemonOntologyG2#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .

#############################################################
# Datos adaptados a ontology_nueva.ttl + shapes_nuevo.ttl
#
# Cambios principales:
# - Se elimina tieneTipoPrimario / tieneTipoSecundario
# - Se usa poke:tieneTipo
# - Se añaden subclases PokemonTipoX
# - Los pokemon duales pertenecen a varias subclases
#############################################################


########################
# Recursos reutilizables
########################

# Generaciones
poke:Gen1 a poke:Generacion ;
    rdfs:label "Generacion 1" .

poke:Gen2 a poke:Generacion ;
    rdfs:label "Generacion 2" .


########################
# Movimientos validos
########################

poke:VineWhip a poke:Movimiento ;
    rdfs:label "Vine Whip" .

poke:Ember a poke:Movimiento ;
    rdfs:label "Ember" .

poke:WaterGun a poke:Movimiento ;
    rdfs:label "Water Gun" .

poke:Thunderbolt a poke:Movimiento ;
    rdfs:label "Thunderbolt" .

poke:RazorLeaf a poke:Movimiento ;
    rdfs:label "Razor Leaf" .


########################
# Recurso incorrecto
########################

poke:Overgrow a poke:Habilidad ;
    rdfs:label "Overgrow" .


#############################################################
# A) Pokemon VALIDOS
#############################################################

#################################################
# Bulbasaur -> dual type
#################################################

poke:Bulbasaur
    a poke:Pokemon ,
      poke:PokemonPlanta ,
      poke:PokemonVeneno ;

    poke:tieneTipo poke:Grass ,
                    poke:Poison ;

    poke:tieneGeneracion poke:Gen1 ;

    poke:hasHP 45 ;
    poke:hasAttack 49 ;
    poke:hasDefense 49 ;
    poke:hasSpAttack 65 ;
    poke:hasSpDefense 65 ;
    poke:hasSpeed 45 ;

    poke:hasExpToLvl100 1059860 ;

    poke:esEvolucionFinal false ;

    poke:evolucionaA poke:Ivysaur ;

    poke:tieneMovimiento poke:VineWhip .



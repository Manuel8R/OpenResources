@prefix poke: <http://pokemon.ontology.com#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .

#############################################################
# Datos de ejemplo para validar las restricciones del shapes.ttl
#
# Este fichero contiene:
# - Instancias conformes, que no deberian producir errores
# - Instancias no conformes, creadas para activar resultados
#   negativos en las distintas restricciones que hemos definido en shapes.ttl 
#
#############################################################


########################
# Clases principales
########################

poke:Pokemon    a rdfs:Class .
poke:Movimiento a rdfs:Class .
poke:Habilidad  a rdfs:Class .




########################
# Recursos reutilizables
########################

# Generaciones
poke:Gen1 a poke:Generacion ;
    rdfs:label "Generacion 1" .

poke:Gen2 a poke:Generacion ;
    rdfs:label "Generacion 2" .

poke:Gen6 a poke:Generacion ;
    rdfs:label "Generacion 6" .


# Movimientos validos
poke:VineWhip a poke:Movimiento ;
    rdfs:label "Vine Whip" .

poke:Ember a poke:Movimiento ;
    rdfs:label "Ember" .

poke:WaterGun a poke:Movimiento ;
    rdfs:label "Water Gun" .

poke:Thunderbolt a poke:Movimiento ;
    rdfs:label "Thunderbolt" .

poke:RazorLeaf a poke:Movimiento ;
    rdfs:label "Razor Leaf" .


# Tipos validos
poke:Grass a poke:Tipo .
poke:Poison a poke:Tipo .
poke:Fire a poke:Tipo .
poke:Water a poke:Tipo .
poke:Electric a poke:Tipo .


# Recurso usado como movimiento incorrecto.
poke:Overgrow a poke:Habilidad ;
    rdfs:label "Overgrow" .


#############################################################
# A) Pokemon validos (para obtener resultado positivos)
#############################################################

poke:Bulbasaur a poke:Pokemon ;
    poke:tieneTipoPrimario poke:Grass ;
    poke:tieneTipoSecundario poke:Poison ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 45 ;
    poke:hasAttack 49 ;
    poke:hasDefense 49 ;
    poke:hasSpAttack 65 ;
    poke:hasSpDefense 65 ;
    poke:hasSpeed 45 ;
    poke:hasExpToLvl100 1059860 ;
    poke:esEvolucionFinal false ;
    poke:evolucionaA poke:Ivysaur ;
    poke:tieneMovimiento poke:VineWhip .

poke:Ivysaur a poke:Pokemon ;
    poke:tieneTipoPrimario poke:Grass ;
    poke:tieneTipoSecundario poke:Poison ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 60 ;
    poke:hasAttack 62 ;
    poke:hasDefense 63 ;
    poke:hasSpAttack 80 ;
    poke:hasSpDefense 80 ;
    poke:hasSpeed 60 ;
    poke:hasExpToLvl100 1059860 ;
    poke:esEvolucionFinal false ;
    poke:evolucionaA poke:Venusaur ;
    poke:tieneMovimiento poke:RazorLeaf .

poke:Venusaur a poke:Pokemon ;
    poke:nombreForma "Venusaur" ;
    poke:tieneTipoPrimario poke:Grass ;
    poke:tieneTipoSecundario poke:Poison ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 80 ;
    poke:hasAttack 82 ;
    poke:hasDefense 83 ;
    poke:hasSpAttack 100 ;
    poke:hasSpDefense 100 ;
    poke:hasSpeed 80 ;
    poke:hasExpToLvl100 1059860 ;
    poke:esEvolucionFinal true ;
    poke:tieneMovimiento poke:RazorLeaf .

poke:Charmander a poke:Pokemon ;
    poke:nombreForma "Charmander" ;
    poke:tieneTipoPrimario poke:Fire ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 39 ;
    poke:hasAttack 52 ;
    poke:hasDefense 43 ;
    poke:hasSpAttack 60 ;
    poke:hasSpDefense 50 ;
    poke:hasSpeed 65 ;
    poke:hasExpToLvl100 1059860 ;
    poke:esEvolucionFinal false ;
    poke:evolucionaA poke:Charmeleon ;
    poke:tieneMovimiento poke:Ember .

poke:Squirtle a poke:Pokemon ;
    poke:nombreForma "Squirtle" ;
    poke:tieneTipoPrimario poke:Water ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 44 ;
    poke:hasAttack 48 ;
    poke:hasDefense 65 ;
    poke:hasSpAttack 50 ;
    poke:hasSpDefense 64 ;
    poke:hasSpeed 43 ;
    poke:hasExpToLvl100 1059860 ;
    poke:esEvolucionFinal false ;
    poke:evolucionaA poke:Wartortle ;
    poke:tieneMovimiento poke:WaterGun .

poke:Pikachu a poke:Pokemon ;
    poke:nombreForma "Pikachu" ;
    poke:tieneTipoPrimario poke:Electric ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 35 ;
    poke:hasAttack 55 ;
    poke:hasDefense 40 ;
    poke:hasSpAttack 50 ;
    poke:hasSpDefense 50 ;
    poke:hasSpeed 90 ;
    poke:hasExpToLvl100 1000000 ;
    poke:esEvolucionFinal false ;
    poke:evolucionaA poke:Raichu ;
    poke:tieneMovimiento poke:Thunderbolt .


#############################################################
# B) Pokemon no valids (para producir erorres)
#############################################################

# B1. Violamos PokemonFinalEvolutionShape:
# esEvolucionFinal debe ser booleano.
poke:Bad_EvolucionFinalNoBooleana a poke:Pokemon ;
    poke:tieneTipoPrimario poke:Fire ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 60 ;
    poke:hasAttack 62 ;
    poke:hasDefense 63 ;
    poke:hasSpAttack 80 ;
    poke:hasSpDefense 80 ;
    poke:hasSpeed 60 ;
    poke:hasExpToLvl100 1059860 ;
    poke:esEvolucionFinal "si" ;
    poke:tieneMovimiento poke:Thunderbolt .


# B2. Violamos PokemonFinalEvolutionShape:
# evolucionaA debe apuntar a un IRI, no a un literal.
poke:Bad_EvolucionaALiteral a poke:Pokemon ;
    poke:tieneTipoPrimario poke:Water ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 35 ;
    poke:hasAttack 55 ;
    poke:hasDefense 40 ;
    poke:hasSpAttack 50 ;
    poke:hasSpDefense 50 ;
    poke:hasSpeed 90 ;
    poke:hasExpToLvl100 1000000 ;
    poke:esEvolucionFinal false ;
    poke:evolucionaA "Wartortle" ;
    poke:tieneMovimiento poke:WaterGun .


# B3. Violamos PokemonMovementClassShape:
# tieneMovimiento apunta a una habilidad, no a un Movimiento.
poke:Bad_MovimientoNoEsMovimiento a poke:Pokemon ;
    poke:tieneTipoPrimario poke:Grass ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 35 ;
    poke:hasAttack 55 ;
    poke:hasDefense 40 ;
    poke:hasSpAttack 50 ;
    poke:hasSpDefense 50 ;
    poke:hasSpeed 90 ;
    poke:hasExpToLvl100 1000000 ;
    poke:esEvolucionFinal false ;
    poke:evolucionaA poke:Raichu ;
    poke:tieneMovimiento poke:Overgrow .


# B4. Violamos PokemonDistinctTypeShape:
# el tipo primario y secundario son iguales.
poke:Bad_TiposIguales a poke:Pokemon ;
    poke:tieneTipoPrimario poke:Fire ;
    poke:tieneTipoSecundario poke:Fire ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 35 ;
    poke:hasAttack 55 ;
    poke:hasDefense 40 ;
    poke:hasSpAttack 50 ;
    poke:hasSpDefense 50 ;
    poke:hasSpeed 90 ;
    poke:hasExpToLvl100 1000000 ;
    poke:esEvolucionFinal true ;
    poke:tieneMovimiento poke:Ember .


# B5. Violamos PokemonAllowedTypesShape:
# "Sound" no esta en la lista cerrada de tipos permitidos.
poke:Bad_TipoPrimarioNoPermitido a poke:Pokemon ;
    poke:tieneTipoPrimario poke:Sound ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 35 ;
    poke:hasAttack 55 ;
    poke:hasDefense 40 ;
    poke:hasSpAttack 50 ;
    poke:hasSpDefense 50 ;
    poke:hasSpeed 90 ;
    poke:hasExpToLvl100 1000000 ;
    poke:esEvolucionFinal true ;
    poke:tieneMovimiento poke:Ember .


# B6. Violamos PokemonAllowedTypesShape:
# falta el tipo primario obligatorio.
poke:Bad_SinTipoPrimario a poke:Pokemon ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 35 ;
    poke:hasAttack 55 ;
    poke:hasDefense 40 ;
    poke:hasSpAttack 50 ;
    poke:hasSpDefense 50 ;
    poke:hasSpeed 90 ;
    poke:hasExpToLvl100 1000000 ;
    poke:esEvolucionFinal true ;
    poke:tieneMovimiento poke:Ember .


# B7. Violamos PokemonSingleGenerationShape:
# el mismo Pokemon pertenece a dos generaciones.
poke:Bad_DosGeneraciones a poke:Pokemon ;
    poke:tieneTipoPrimario poke:Psychic ;
    poke:tieneGeneracion poke:Gen1, poke:Gen2 ;
    poke:hasHP 35 ;
    poke:hasAttack 55 ;
    poke:hasDefense 40 ;
    poke:hasSpAttack 50 ;
    poke:hasSpDefense 50 ;
    poke:hasSpeed 90 ;
    poke:hasExpToLvl100 1000000 ;
    poke:esEvolucionFinal true ;
    poke:tieneMovimiento poke:Thunderbolt .


# B8. Violamos PokemonSingleGenerationShape:
# falta la generacion obligatoria.
poke:Bad_SinGeneracion a poke:Pokemon ;
    poke:tieneTipoPrimario poke:Psychic ;
    poke:hasHP 35 ;
    poke:hasAttack 55 ;
    poke:hasDefense 40 ;
    poke:hasSpAttack 50 ;
    poke:hasSpDefense 50 ;
    poke:hasSpeed 90 ;
    poke:hasExpToLvl100 1000000 ;
    poke:esEvolucionFinal true ;
    poke:tieneMovimiento poke:Thunderbolt .


# B9. Violamos PokemonSingleFormShape:
# no se permite mas de una forma para un mismo recurso.
poke:Bad_DosFormas a poke:Pokemon ;
    poke:tieneFormaRegional poke:FormaNormal, poke:FormaRegional ;
    poke:tieneTipoPrimario poke:Dragon ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 35 ;
    poke:hasAttack 55 ;
    poke:hasDefense 40 ;
    poke:hasSpAttack 50 ;
    poke:hasSpDefense 50 ;
    poke:hasSpeed 90 ;
    poke:hasExpToLvl100 1000000 ;
    poke:esEvolucionFinal true ;
    poke:tieneMovimiento poke:RazorLeaf .


# B10. Violamos PokemonExpShape:
# la experiencia para alcanzar el nivel 100 debe ser mayor a 0.
poke:Bad_NivelFueraDeRango a poke:Pokemon ;
    poke:tieneTipoPrimario poke:Ice ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 35 ;
    poke:hasAttack 55 ;
    poke:hasDefense 40 ;
    poke:hasSpAttack 50 ;
    poke:hasSpDefense 50 ;
    poke:hasSpeed 90 ;
    poke:hasExpToLvl100 -2 ;
    poke:esEvolucionFinal true ;
    poke:tieneMovimiento poke:RazorLeaf .


# B11. Violamos PokemonExpShape:
# el nivel debe ser un entero.
poke:Bad_NivelNoEntero a poke:Pokemon ;
    poke:tieneTipoPrimario poke:Ice ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 35 ;
    poke:hasAttack 55 ;
    poke:hasDefense 40 ;
    poke:hasSpAttack 50 ;
    poke:hasSpDefense 50 ;
    poke:hasSpeed 90 ;
    poke:hasExpToLvl100 "nose el nivel" ;
    poke:esEvolucionFinal false ;
    poke:tieneMovimiento poke:RazorLeaf .


# B12. Violamos PokemonBaseStatsPositiveShape:
# hp debe ser un entero positivo.
poke:Bad_HPNoPositivo a poke:Pokemon ;
    poke:tieneTipoPrimario poke:Rock ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 35 ;
    poke:hasAttack 55 ;
    poke:hasDefense 40 ;
    poke:hasSpAttack 50 ;
    poke:hasSpDefense 50 ;
    poke:hasSpeed 0 ;
    poke:hasExpToLvl100 4334 ;
    poke:esEvolucionFinal true ;
    poke:tieneMovimiento poke:RazorLeaf .


# B13. Violamos PokemonBaseStatsPositiveShape:
# attack debe ser entero, no texto.
poke:Bad_AttackNoEntero a poke:Pokemon ;
    poke:tieneTipoPrimario poke:Fighting ;
    poke:tieneGeneracion poke:Gen1 ;
    poke:hasHP 35 ;
    poke:hasAttack "cuarenta" ;
    poke:hasDefense 40 ;
    poke:hasSpAttack 50 ;
    poke:hasSpDefense 50 ;
    poke:hasSpeed 70 ;
    poke:hasExpToLvl100 4334 ;
    poke:esEvolucionFinal false ;
    poke:tieneMovimiento poke:RazorLeaf .

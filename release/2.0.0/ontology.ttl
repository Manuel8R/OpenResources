###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
<http://www.w3.org/2004/02/skos/core#ConceptScheme> rdf:type owl:Class .


###  https://w3id.org/doisr/PokemonOntologyG2#Categoria
:Categoria rdf:type owl:Class ;
           rdfs:label "Categoria" .


###  https://w3id.org/doisr/PokemonOntologyG2#Color
:Color rdf:type owl:Class ;
       rdfs:label "Color" .


###  https://w3id.org/doisr/PokemonOntologyG2#FaseEvolutiva
:FaseEvolutiva rdf:type owl:Class ;
               rdfs:label "Fase Evolutiva" .


###  https://w3id.org/doisr/PokemonOntologyG2#FormaRegional
:FormaRegional rdf:type owl:Class ;
               rdfs:label "Forma Regional" .


###  https://w3id.org/doisr/PokemonOntologyG2#Generacion
:Generacion rdf:type owl:Class ;
            rdfs:label "Generacion" .


###  https://w3id.org/doisr/PokemonOntologyG2#Grupohuevo
:Grupohuevo rdf:type owl:Class ;
            rdfs:label "Grupohuevo" .


###  https://w3id.org/doisr/PokemonOntologyG2#Habilidad
:Habilidad rdf:type owl:Class ;
           rdfs:label "Habilidad" .


###  https://w3id.org/doisr/PokemonOntologyG2#Movimiento
:Movimiento rdf:type owl:Class ;
            owl:disjointWith :Pokemon ,
                             :Tipo ;
            rdfs:label "Movimiento" .


###  https://w3id.org/doisr/PokemonOntologyG2#Pokemon
:Pokemon rdf:type owl:Class ;
         rdfs:subClassOf [ rdf:type owl:Restriction ;
                           owl:onProperty :tieneTipo ;
                           owl:minCardinality "1"^^xsd:nonNegativeInteger
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :tieneTipo ;
                           owl:maxCardinality "2"^^xsd:nonNegativeInteger
                         ] ;
         owl:disjointWith :Tipo ;
         rdfs:label "Pokemon" .


###  https://w3id.org/doisr/PokemonOntologyG2#PokemonAcero
:PokemonAcero rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Restriction ;
                                    owl:onProperty :tieneTipo ;
                                    owl:hasValue :Steel
                                  ] ;
              rdfs:subClassOf :Pokemon ;
              rdfs:label "Pokemon Acero" .


###  https://w3id.org/doisr/PokemonOntologyG2#PokemonAgua
:PokemonAgua rdf:type owl:Class ;

@prefix : <https://w3id.org/doisr/PokemonOntologyG2#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/doisr/PokemonOntologyG2> .

<https://w3id.org/doisr/PokemonOntologyG2> rdf:type owl:Ontology ;
                                            owl:versionIRI <https://w3id.org/doisr/PokemonOntologyG2/2.1.0> ;
                                            <http://purl.org/dc/elements/1.1/creator> "Daniel Javier Flores Flores"@es ,
                                                                                      "Manuel Bravo Roig"@es ,
                                                                                      "Pablo Calle Tercero"@es ;
                                            <http://purl.org/dc/elements/1.1/date> "2026-05-13"^^xsd:date ;
                                            <http://purl.org/dc/elements/1.1/description> "Ontologia para relacionar pokemons con sus evoluciones, atributos, habilidades, stats..."@es ;
                                            <http://purl.org/dc/elements/1.1/title> "Ontologia de Pokemon"@es ;
                                            <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                            <http://purl.org/dc/terms/publisher> "Universidad Politécnica de Madrid"@en ;
                                            <http://purl.org/dc/terms/source> <https://www.kaggle.com/datasets/divyadeep/pokemon> ,
                                                                              <https://www.kaggle.com/datasets/maca11/all-pokemon-dataset> ,
                                                                              <https://www.kaggle.com/datasets/takamasakato/pokemon-all-status-data> ;
                                            <http://purl.org/vocab/vann/preferredNamespacePrefix> "poke" ;
                                            <http://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/doisr/PokemonOntologyG2" ;
                                            owl:backwardCompatibleWith <https://w3id.org/doisr/PokemonOntologyG2/2.0.0> ;
                                            owl:priorVersion <https://w3id.org/doisr/PokemonOntologyG2/2.0.0> ;
                                            owl:versionInfo "2.1.0" .


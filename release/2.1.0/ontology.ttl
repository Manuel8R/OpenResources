###  https://w3id.org/doisr/PokemonOntologyG2#PokemonHielo
:PokemonHielo rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Restriction ;
                                    owl:onProperty :tieneTipo ;
                                    owl:hasValue :Ice
                                  ] ;

xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################


###  https://w3id.org/doisr/PokemonOntologyG2#fuerteContra
:fuerteContra rdf:type owl:ObjectProperty ;
              owl:inverseOf :debilContra ;
              rdfs:domain :Tipo ;
              rdfs:range :Tipo ;
              rdfs:label "fuerte contra"@es ;
              rdfs:comment "Indica que este tipo es fuerte (tiene multiplicador x2) contra otro."@es .
            

###  https://w3id.org/doisr/PokemonOntologyG2#debilContra
:debilContra rdf:type owl:ObjectProperty ;
             rdfs:domain :Tipo ;
             rdfs:range :Tipo ;
             rdfs:label "debil contra"@es ;
             rdfs:comment "Indica que este tipo es debil (tiene multiplicador x2) contra otro."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#evolucionaA
:evolucionaA rdf:type owl:ObjectProperty ;
             owl:inverseOf :evolucionaDe ;
             rdfs:domain :Pokemon ;
             rdfs:range :Pokemon ;
             rdfs:label "evoluciona a"@es ;
             rdfs:comment "Indica que este pokemon puede evolucionar a otro."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#evolucionaDe
:evolucionaDe rdf:type owl:ObjectProperty ;
              rdfs:domain :Pokemon ;
              rdfs:range :Pokemon ;
              rdfs:label "evoluciona de"@es ;
              rdfs:comment "Indica que este pokemon ha evolucionado de otro."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#tieneCategoria
:tieneCategoria rdf:type owl:ObjectProperty ;
                rdfs:domain :Pokemon ;
                rdfs:range :Categoria ;
                rdfs:label "tiene categoria" ;
                rdfs:comment "Indica que este pokemon pertenece a una categoria."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#tieneColor
:tieneColor rdf:type owl:ObjectProperty ;
            rdfs:domain :Pokemon ;
            rdfs:range :Color ;
            rdfs:label "tiene color" ;
            rdfs:comment "Indica que este pokemon tiene cierto color."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#tieneFaseEvolutiva
:tieneFaseEvolutiva rdf:type owl:ObjectProperty ;
                    rdfs:domain :Pokemon ;
                    rdfs:range :FaseEvolutiva ;
                    rdfs:label "tiene fase evolutiva" ;
                    rdfs:comment "Indica la fase evolutiva del pokemon (1, 2, 3)."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#tieneFormaRegional
:tieneFormaRegional rdf:type owl:ObjectProperty ;
                    rdfs:domain :Pokemon ;
                    rdfs:range :FormaRegional ;
                    rdfs:label "tiene forma regional" ;
                    rdfs:comment "Indica la forma regional."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#tieneGeneracion
:tieneGeneracion rdf:type owl:ObjectProperty ;
                 rdfs:domain :Pokemon ;
                 rdfs:range :Generacion ;
                 rdfs:label "tiene generacion" ;
                 rdfs:comment "Indica de que generacion es el pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#tieneGrupoHuevo
:tieneGrupoHuevo rdf:type owl:ObjectProperty ;
                 rdfs:domain :Pokemon ;
                 rdfs:range :Grupohuevo ;
                 rdfs:label "tiene grupo huevo" ;
                 rdfs:comment "Indica de que grupo es el huevo del pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#tieneHabilidad
:tieneHabilidad rdf:type owl:ObjectProperty ;
                rdfs:domain :Pokemon ;
                rdfs:range :Habilidad ;
                rdfs:label "tiene habilidad" ;
                rdfs:comment "Indica la/s habilidad/es pasivas del pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#tieneHabilidadSecreta
:tieneHabilidadSecreta rdf:type owl:ObjectProperty ;
                       rdfs:domain :Pokemon ;
                       rdfs:range :Habilidad ;
                       rdfs:label "tiene habilidad secreta" ;
                       rdfs:comment "Indica que habilidad secreta tiene el pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#tieneMovimiento
:tieneMovimiento rdf:type owl:ObjectProperty ;
                 rdfs:domain :Pokemon ;
                 rdfs:range :Movimiento ;
                 rdfs:label "tiene Movimiento" ;
                 rdfs:comment "Indica que este pokemon puede aprender este movimiento."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#tieneTipo
:tieneTipo rdf:type owl:ObjectProperty ;
           rdfs:domain :Pokemon ;
           rdfs:range :Tipo ;
           rdfs:label "tiene tipo" ;
           rdfs:comment "Indica que tipo tiene un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#tieneTipoExperiencia
:tieneTipoExperiencia rdf:type owl:ObjectProperty ;
                      rdfs:domain :Pokemon ;
                      rdfs:range :TipoExperiencia ;
                      rdfs:label "tiene tipo experiencia" ;
                      rdfs:comment "Indica que tipo de experiencia tiene el pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#tipoMovimiento
:tipoMovimiento rdf:type owl:ObjectProperty ;
                rdfs:domain :Movimiento ;
                rdfs:range :Tipo ;
                rdfs:label "tipo de movimiento" ;
                rdfs:comment "Indica el tipo del movimiento."@es .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/doisr/PokemonOntologyG2#esEvolucionFinal
:esEvolucionFinal rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Pokemon ;
                  rdfs:range xsd:boolean ;
                  rdfs:label "is final evolution" ;
                  rdfs:comment "Indica si es un pokemon es la evolucion final o no."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#hasAttack
:hasAttack rdf:type owl:DatatypeProperty ;
           rdfs:domain :Pokemon ;
           rdfs:range xsd:int ;
           rdfs:label "has attack" ;
           rdfs:comment "Cuantos puntos de ataque tiene un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#hasBMI
:hasBMI rdf:type owl:DatatypeProperty ;
        rdfs:domain :Pokemon ;
        rdfs:range xsd:float ;
        rdfs:label "has BMI" ;
        rdfs:comment "Cual es el BMI de un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#hasBST
:hasBST rdf:type owl:DatatypeProperty ;
        rdfs:domain :Pokemon ;
        rdfs:range xsd:int ;
        rdfs:label "has BST" ;
        rdfs:comment "Cual es el BST de un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#hasBaseExperience
:hasBaseExperience rdf:type owl:DatatypeProperty ;
                   rdfs:domain :Pokemon ;
                   rdfs:range xsd:int ;
                   rdfs:label "has base experience" ;
                   rdfs:comment "Cuantos puntos de experiencia base tiene un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#hasCatchRate
:hasCatchRate rdf:type owl:DatatypeProperty ;
              rdfs:domain :Pokemon ;
              rdfs:range xsd:int ;
              rdfs:label "has catch rate" ;
              rdfs:comment "Cual es el ratio de captura de un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#hasDefense
:hasDefense rdf:type owl:DatatypeProperty ;
            rdfs:domain :Pokemon ;
            rdfs:range xsd:int ;
            rdfs:label "has defense" ;
            rdfs:comment "Cuantos puntos de defensa tiene un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#hasEggSteps
:hasEggSteps rdf:type owl:DatatypeProperty ;
             rdfs:domain :Pokemon ;
             rdfs:range xsd:int ;
             rdfs:label "has egg steps" ;
             rdfs:comment "Cuantos pasos se necesitan para un huevo."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#hasExpToLvl100
:hasExpToLvl100 rdf:type owl:DatatypeProperty ;
                rdfs:domain :Pokemon ;
                rdfs:range xsd:int ;
                rdfs:label "has exp to lvl100" ;
                rdfs:comment "Cuantos puntos de experiencia se necesitan para llegar al nivel 100."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#hasGenderFemaleRatio
:hasGenderFemaleRatio rdf:type owl:DatatypeProperty ;
                      rdfs:domain :Pokemon ;
                      rdfs:range xsd:float ;
                      rdfs:label "has gender female ratio" ;
                      rdfs:comment "Cual es el ratio de pokemons hembra."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#hasGenderMaleRatio
:hasGenderMaleRatio rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Pokemon ;
                    rdfs:range xsd:float ;
                    rdfs:label "has gender male ratio" ;
                    rdfs:comment "Cual es el ratio de pokemons macho."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#hasHP
:hasHP rdf:type owl:DatatypeProperty ;
       rdfs:domain :Pokemon ;
       rdfs:range xsd:int ;
       rdfs:label "has hp" ;
       rdfs:comment "Cuantos puntos de vida tiene un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#hasHeight
:hasHeight rdf:type owl:DatatypeProperty ;
           rdfs:domain :Pokemon ;
           rdfs:range xsd:float ;
           rdfs:label "has height" ;
           rdfs:comment "Cual es la altura de un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#hasSpAttack
:hasSpAttack rdf:type owl:DatatypeProperty ;
             rdfs:domain :Pokemon ;
             rdfs:range xsd:int ;
             rdfs:label "has sp attack" ;
             rdfs:comment "Cuantos puntos de ataque especial tiene un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#hasSpDefense
:hasSpDefense rdf:type owl:DatatypeProperty ;
              rdfs:domain :Pokemon ;
              rdfs:range xsd:int ;
              rdfs:label "has sp defense" ;
              rdfs:comment "Cuantos puntos de defensa especial tiene un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#hasSpeed
:hasSpeed rdf:type owl:DatatypeProperty ;
          rdfs:domain :Pokemon ;
          rdfs:range xsd:int ;
          rdfs:label "hasSpeed" ;
          rdfs:comment "Cuantos puntos de velocidad tiene un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#hasWeight
:hasWeight rdf:type owl:DatatypeProperty ;
           rdfs:domain :Pokemon ;
           rdfs:range xsd:float ;
           rdfs:label "has weight" ;
           rdfs:comment "Cual es el peso de un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#isLegendary
:isLegendary rdf:type owl:DatatypeProperty ;
             rdfs:domain :Pokemon ;
             rdfs:range xsd:boolean ;
             rdfs:label "is legendary" ;
             rdfs:comment "Indica si un pokemon es legendario o no."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#potenciaMovimiento
:potenciaMovimiento rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Movimiento ;
                    rdfs:range xsd:int ;
                    rdfs:label "potencia movimiento" ;
                    rdfs:comment "Indica la potencia (daño base) de un movimiento."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#precisionMovimiento
:precisionMovimiento rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Movimiento ;
                     rdfs:range xsd:int ;
                     rdfs:label "precision movimiento" ;
                     rdfs:comment "Indica la precision de un movimiento."@es .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
<http://www.w3.org/2004/02/skos/core#ConceptScheme> rdf:type owl:Class .


###  https://w3id.org/doisr/PokemonOntologyG2#Categoria
:Categoria rdf:type owl:Class ;
           rdfs:label "Categoria" ;
           rdfs:comment "Las categorias que existen de pokemons (ordinary, mythical, semi-legendary o legendary)."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#Color
:Color rdf:type owl:Class ;
       rdfs:label "Color" ;
       rdfs:comment "Los posibles colores que puede tener un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#FaseEvolutiva
:FaseEvolutiva rdf:type owl:Class ;
               rdfs:label "Fase Evolutiva" ;
               rdfs:comment "Que fases evolutivas hay."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#FormaRegional
:FormaRegional rdf:type owl:Class ;
               rdfs:label "Forma Regional" ;
               rdfs:comment "Que formas regionales puede tomar un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#Generacion
:Generacion rdf:type owl:Class ;
            rdfs:label "Generacion" ;
            rdfs:comment "Las generaciones de pokemons que hay (1, 2, 3...)."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#Grupohuevo
:Grupohuevo rdf:type owl:Class ;
            rdfs:label "Grupohuevo" ;
            rdfs:comment "Los grupos de huevo que puede haber."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#Habilidad
:Habilidad rdf:type owl:Class ;
           rdfs:label "Habilidad" ;
           rdfs:comment "Las habilidades pasivas que puede tener un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#Movimiento
:Movimiento rdf:type owl:Class ;
            owl:disjointWith :Pokemon ,
                             :Tipo ;
            rdfs:label "Movimiento" ;
            rdfs:comment "Los movimientos que puede realizar un pokemon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#Pokemon
:Pokemon rdf:type owl:Class ;
         rdfs:subClassOf [ rdf:type owl:Restriction ;
                           owl:onProperty :tieneTipo ;
                           owl:minCardinality "1"^^xsd:nonNegativeInteger
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :tieneTipo ;
                           owl:maxCardinality "2"^^xsd:nonNegativeInteger
                         ] ;
         owl:disjointWith :Tipo ;
         rdfs:label "Pokemon" ;
         rdfs:comment "Clase que representa un Pokémon dentro de la ontología."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#PokemonAcero
:PokemonAcero rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Restriction ;
                                    owl:onProperty :tieneTipo ;
                                    owl:hasValue :Steel
                                  ] ;
              rdfs:subClassOf :Pokemon ;
              rdfs:label "Pokemon Acero" ;
              rdfs:comment "Sub-clase de pokemon que representa un Pokémon de tipo acero."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#PokemonAgua
:PokemonAgua rdf:type owl:Class ;
             owl:equivalentClass [ rdf:type owl:Restriction ;
                                   owl:onProperty :tieneTipo ;
                                   owl:hasValue :Water
                                 ] ;
             rdfs:subClassOf :Pokemon ;
             rdfs:label "Pokemon Agua" ;
             rdfs:comment "Sub-clase de pokemon que representa un Pokémon de tipo agua."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#PokemonBicho
:PokemonBicho rdf:type owl:Class ;
              owl:equivalentClass [ rdf:type owl:Restriction ;
                                    owl:onProperty :tieneTipo ;
                                    owl:hasValue :Bug
                                  ] ;
              rdfs:subClassOf :Pokemon ;
              rdfs:label "Pokemon Bicho" ;
              rdfs:comment "Sub-clase de pokemon que representa un Pokémon de tipo bicho."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#PokemonDragon
:PokemonDragon rdf:type owl:Class ;
               owl:equivalentClass [ rdf:type owl:Restriction ;
                                     owl:onProperty :tieneTipo ;
                                     owl:hasValue :Dragon
                                   ] ;
               rdfs:subClassOf :Pokemon ;
               rdfs:label "Pokemon Dragon" ;
               rdfs:comment "Sub-clase de pokemon que representa un Pokémon de tipo dragon."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#PokemonElectrico
:PokemonElectrico rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Restriction ;
                                        owl:onProperty :tieneTipo ;
                                        owl:hasValue :Electric
                                      ] ;
                  rdfs:subClassOf :Pokemon ;
                  rdfs:label "Pokemon Electrico" ;
                  rdfs:comment "Sub-clase de pokemon que representa un Pokémon de tipo electrico."@es .


###  https://w3id.org/doisr/PokemonOntologyG2#PokemonFantasma
:PokemonFantasma rdf:type owl:Class ;
                 owl:equivalentClass [ rdf:type owl:Restriction ;

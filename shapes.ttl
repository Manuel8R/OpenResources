@prefix pokemon: <http://pokemon.ontology.com#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .

#############################################################
# Shapes para cada clase en los dataset validando evoluciones,
# tipos, generaciones, movimientos y estadísticas base:
# 1. Si es evolucion final evoluciona de otro
# 2. Si tiene moviento tiene que ser del tipo movimiento
# 3. Que no puede ser el tipo principal y el secundario igual
# 4. El tipo tiene que estar en la lista
# 5. EL mismo pokemon no puede ser de dos generaciones distintas
# 6. El pokemon no puede ser de dos formas distintas
# 7. Todo pokemon tiene que tener nivel y estar entre (0, 100]
# 8. Ningun valor de las estadisticas base puede ser 0<=
#############################################################

#-----------------------------------------------------------
# 1. Si es evolucion final evoluciona de otro
#    - Si un Pokémon está marcado como evolución final (true),
#      no puede poseer una propiedad que apunte a una evolución posterior.
#-----------------------------------------------------------
pokemon:PokemonFinalEvolutionShape
    a sh:NodeShape ;
    sh:targetClass pokemon:Pokemon ;
    rdfs:label "Lógica de evolución final" ;

    sh:sparql [
        sh:message "Un Pokémon marcado como evolución final no puede tener el campo 'evolucionaA'." ;
        sh:prefixes [
            sh:declare [ sh:prefix "pokemon" ; sh:namespace "http://example.org/pokemon#"^^xsd:anyURI ] ;
        ] ;
        sh:select """
            SELECT $this
            WHERE {
                $this pokemon:esEvolucionFinal true .
                $this pokemon:evolucionaA ?next .
            }
        """ ;
    ] .

#-----------------------------------------------------------
# 2. Si tiene moviento tiene que ser del tipo movimiento
#    - Si un Pokémon tiene movimientos asociados, estos deben
#      ser obligatoriamente instancias de la clase pokemon:Movimiento.
#-----------------------------------------------------------
pokemon:PokemonMovementClassShape
    a sh:NodeShape ;
    sh:targetClass pokemon:Pokemon ;
    rdfs:label "Validación de clase para movimientos" ;

    sh:property [
        sh:path pokemon:tieneMovimiento ;
        sh:class pokemon:Movimiento ;
        sh:nodeKind sh:IRI ;
        sh:message "Cualquier objeto en 'tieneMovimiento' debe ser un IRI de la clase pokemon:Movimiento." ;
    ] .

#-----------------------------------------------------------
# 3. Que no puede ser el tipo principal y el secundario igual
#    - Un Pokémon no puede tener el mismo tipo asignado como
#      primario y secundario simultáneamente.
#-----------------------------------------------------------
pokemon:PokemonDistinctTypeShape
    a sh:NodeShape ;
    sh:targetClass pokemon:Pokemon ;
    rdfs:label "Unicidad de tipos primario y secundario" ;

    sh:sparql [
        sh:message "El tipo primario y el tipo secundario no pueden ser idénticos." ;
        sh:prefixes [
            sh:declare [ sh:prefix "pokemon" ; sh:namespace "http://example.org/pokemon#"^^xsd:anyURI ] ;
        ] ;
        sh:select """
            SELECT $this ?tipo
            WHERE {
                $this pokemon:tieneTipoPrimario ?tipo ;
                      pokemon:tieneTipoSecundario ?tipo .
            }
        """ ;
    ] .

#-----------------------------------------------------------
# 4. El tipo tiene que estar en la lista
#    - El valor de los tipos debe pertenecer estrictamente a la
#      enumeración de los 18 tipos oficiales de la franquicia.
#-----------------------------------------------------------
pokemon:PokemonAllowedTypesShape
    a sh:NodeShape ;
    sh:targetClass pokemon:Pokemon ;
    rdfs:label "Tipos permitidos (lista cerrada)" ;

    sh:property [
        sh:path ( pokemon:tieneTipoPrimario pokemon:tieneTipoSecundario ) ;
        sh:in ( "Grass" "Poison" "Fire" "Flying" "Water" "Bug" "Normal" "Electric" "Ground" "Fairy" "Fighting" "Psychic" "Rock" "Steel" "Ice" "Ghost" "Dragon" "Dark" ) ;
        sh:message "El tipo asignado no es un tipo Pokémon válido." ;
    ] .

#-----------------------------------------------------------
# 5. EL mismo pokemon no puede ser de dos generaciones distintas
#    - Un Pokémon debe pertenecer a una única generación.
#-----------------------------------------------------------
pokemon:PokemonSingleGenerationShape
    a sh:NodeShape ;
    sh:targetClass pokemon:Pokemon ;
    rdfs:label "Cardinalidad de generación" ;

    sh:property [
        sh:path pokemon:perteneceAGeneracion ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:message "Cada Pokémon debe estar asociado exactamente a una generación." ;
    ] .

#-----------------------------------------------------------
# 6. El pokemon no puede ser de dos formas distintas
#    - Cada registro de Pokémon debe representar una única forma.
#-----------------------------------------------------------
pokemon:PokemonSingleFormShape
    a sh:NodeShape ;
    sh:targetClass pokemon:Pokemon ;
    rdfs:label "Cardinalidad de forma" ;

    sh:property [
        sh:path pokemon:nombreForma ;
        sh:maxCount 1 ;
        sh:message "No se permite definir más de una forma para un mismo recurso Pokémon." ;
    ] .

#-----------------------------------------------------------
# 7. Todo pokemon tiene que tener nivel y estar entre (0, 100]
#    - El nivel es obligatorio y debe ser un entero en el rango (0, 100].
#-----------------------------------------------------------
pokemon:PokemonLevelShape
    a sh:NodeShape ;
    sh:targetClass pokemon:Pokemon ;
    rdfs:label "Rango de nivel permitido" ;

    sh:property [
        sh:path pokemon:nivel ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ;
        sh:maxInclusive 100 ;
        sh:message "El nivel debe ser un número entero entre 1 y 100." ;
    ] .

#-----------------------------------------------------------
# 8. Ningun valor de las estadisticas base puede ser 0<=
#    - Ninguna estadística base (HP, Ataque, Defensa, etc.) puede
#      ser igual o inferior a cero.
#-----------------------------------------------------------
pokemon:PokemonBaseStatsPositiveShape
    a sh:NodeShape ;
    sh:targetClass pokemon:Pokemon ;
    rdfs:label "Validación de estadísticas positivas" ;

    sh:property [
        sh:path ( pokemon:hp pokemon:attack pokemon:defense pokemon:spAtk pokemon:spDef pokemon:speed ) ;
        sh:minInclusive 1 ;
        sh:message "Las estadísticas base deben ser siempre mayores o iguales a 1." ;
    ] .

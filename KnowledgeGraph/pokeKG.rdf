    <!-- http://pokemon.ontology.com#Movimiento -->

    <owl:Class rdf:about="http://pokemon.ontology.com#Movimiento">
        <owl:disjointWith rdf:resource="http://pokemon.ontology.com#Pokemon"/>
        <owl:disjointWith rdf:resource="http://pokemon.ontology.com#Tipo"/>
        <rdfs:label>Movimiento</rdfs:label>
    </owl:Class>
    


    <!-- http://pokemon.ontology.com#Pokemon -->

    <owl:Class rdf:about="http://pokemon.ontology.com#Pokemon">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://pokemon.ontology.com#tieneTipo"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://pokemon.ontology.com#tieneTipo"/>
                <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:maxCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://pokemon.ontology.com#Tipo"/>
        <rdfs:label>Pokemon</rdfs:label>
    </owl:Class>
    


    <!-- http://pokemon.ontology.com#PokemonAcero -->

    <owl:Class rdf:about="http://pokemon.ontology.com#PokemonAcero">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://pokemon.ontology.com#tieneTipo"/>
                <owl:hasValue rdf:resource="http://pokemon.ontology.com#Steel"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://pokemon.ontology.com#Pokemon"/>
        <rdfs:label>Pokemon Acero</rdfs:label>
    </owl:Class>
    



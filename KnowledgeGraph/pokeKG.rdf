     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:poke="http://pokemon.ontology.com#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:other="http://example.org/other#"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://pokemon.ontology.com#">
        <owl:versionIRI rdf:resource="http://pokemon.ontology.com/ontology/2.0.0"/>
        <owl:imports rdf:resource="http://pokemon.ontology.com/ontology/2.0.0"/>
        <dc:creator>Manuel Bravo, Pablo Calle, </dc:creator>
        <dc:date rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-10</dc:date>
        <dc:description xml:lang="es">Ontologia para relacionar pokemons con sus evoluciones, atributos, habilidades, stats...</dc:description>
        <dc:title xml:lang="es">Ontologia de Pokemon</dc:title>
        <owl:versionInfo>2.0.0</owl:versionInfo>
        <mod:createdWith rdf:resource="https://chowlk.linkeddata.es/"/>
    </owl:Ontology>
    


